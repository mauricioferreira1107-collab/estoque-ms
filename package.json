{
  "name": "estoque-ms",
  "version": "1.0.0",
  "description": "MS Pinturas - Controle de Estoque (SPA client-side)",
  "private": true,
  "scripts": {
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,html,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,html,md}\"",
    "serve": "python3 -m http.server 8080",
    "test": "playwright test",
    "test:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3"
  }
}
